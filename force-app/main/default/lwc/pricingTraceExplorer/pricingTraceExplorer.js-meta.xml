<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Pricing Trace Explorer</masterLabel>
    <description>Revenue Cloud pricing traceability console with adjustment breakdowns, procedure visibility, and replay simulation.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage">
            <property
                name="demoMode"
                type="Boolean"
                label="Start In Demo Mode"
                description="Loads the built-in portfolio dataset instead of attempting live Revenue Cloud trace discovery."
            />
            <supportedFormFactors>
                <supportedFormFactor type="Large" />
                <supportedFormFactor type="Small" />
            </supportedFormFactors>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
